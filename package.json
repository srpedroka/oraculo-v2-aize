{
  "name": "oraculo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit --pretty false",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:security": "vitest run --config vitest.security.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:staging": "E2E_STAGING=true playwright test",
    "test:fixtures": "pnpm run test:historical-import && pnpm run test:kpi-format && pnpm run test:conversation-memory",
    "test:historical-import": "node --experimental-strip-types scripts/verify-historical-import.ts",
    "test:kpi-format": "node --experimental-strip-types scripts/verify-kpi-format.ts",
    "test:conversation-memory": "node --experimental-strip-types scripts/verify-conversation-memory.ts",
    "verify:deploy": "node --experimental-strip-types scripts/verify-deploy.ts",
    "check": "pnpm run lint && pnpm run test && pnpm run build"
  },
  "dependencies": {
    "@fontsource/inter": "^5.0.20",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-query": "^5.101.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "recharts": "^2.12.7",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.20.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "jsdom": "^29.1.1",
    "pdf-lib": "1.17.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.9"
  }
}
